# knowledgeLLM app configuration (KTD5). Copy to .env and fill in.
# .env is gitignored — never commit real secrets.

# --- App ---
PORT=3000
# Long random string used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string
# Set to true only when serving over HTTPS (sets the Secure cookie flag).
COOKIE_SECURE=false
# Registration policy: after the first (bootstrap) account exists, new
# registrations are only allowed when this is true (R29).
ALLOW_REGISTRATION=false

# --- Database ---
DATABASE_URL="file:./prisma/dev.db"

# --- CyborgDB (cyborgdb-service) ---
# Reachable from inside the docker-compose network as the service hostname.
CYBORGDB_URL=http://cyborgdb-service:8000
# OPTIONAL — leave BLANK for local/self-hosted use (the service runs with auth
# disabled by default). Only set this if you also set CYBORGDB_SERVICE_ROOT_KEY
# on the service to require auth; then the two must match.
CYBORGDB_API_KEY=
# OPTIONAL — cyborgdb-core license key. Blank = free tier (1M items/index).
CYBORGDB_LICENSE_KEY=

# --- Ollama (optional default hint only; the operator sets the real URL in setup) ---
# NOTE: inside Docker, "localhost" points at the container, not your host.
# Use http://host.docker.internal:11434 (Mac/Windows) or your host's LAN IP.
OLLAMA_DEFAULT_URL=http://host.docker.internal:11434
