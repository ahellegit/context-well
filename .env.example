# Context Well app configuration (KTD5). Copy to .env and fill in.
# .env is gitignored — never commit real secrets.

# --- App ---
PORT=3000
# Long random string used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string
# Set to true only when serving over HTTPS (sets the Secure cookie flag).
COOKIE_SECURE=false
# Master key for at-rest encryption of sensitive DB columns (chat text, connector
# credentials, CyborgDB index keys, etc). REQUIRED — the app refuses to boot without
# it. Generate with: npx cloak generate  (format: k1.aesgcm256.<base64 32-byte key>)
# Inject via env/secret; do NOT commit it or store it on the DB volume. Losing this
# key makes encrypted data unrecoverable, so back it up. Rotate by moving the old key
# into PRISMA_FIELD_DECRYPTION_KEYS (comma-separated) and setting a new key here.
PRISMA_FIELD_ENCRYPTION_KEY=k1.aesgcm256.change-me-generate-with-npx-cloak-generate
# Note: open self-registration was removed with app-layer RBAC. The first account
# bootstraps as the workspace owner; everyone else is admin-provisioned from the
# Members view. There is no ALLOW_REGISTRATION setting.

# --- Database ---
DATABASE_URL="file:./prisma/dev.db"

# --- CyborgDB (cyborgdb-service) ---
# Reachable from inside the docker-compose network as the service hostname.
# The service runs with auth disabled and the free tier, so no key is needed.
CYBORGDB_URL=http://cyborgdb-service:8000
# After the embedding model is cached (first run), set this to 1 and recreate
# cyborgdb-service for a ~35x faster embed/query (skips per-query HuggingFace
# checks). Leave 0 for the very first deploy. See docs/CYBORGDB-ISSUES.md #1.
CYBORGDB_HF_OFFLINE=0

# --- Ollama (optional default hint only; the operator sets the real URL in setup) ---
# NOTE: inside Docker, "localhost" points at the container, not your host. The
# app's SSRF guard also blocks private IP literals (192.168/10/172.16 ranges), so
# a host LAN IP will be refused. Use the hostname http://host.docker.internal:11434
# instead — on Linux this requires the extra_hosts:host-gateway mapping that
# docker-compose.yml already sets for the app service.
OLLAMA_DEFAULT_URL=http://host.docker.internal:11434
